# shellcheck disable=SC2006

prefix='/data/data/com.termux/files/usr'
# Used in 'libdir'
# shellcheck disable=SC2034
exec_prefix="${prefix}"
# shellcheck disable=SC2034
includedir="/data/data/com.termux/files/usr/include"

usage()
{
  cat <<EOF
Usage: curl-config [OPTION]

Available values for OPTION include:

  --built-shared        says 'yes' if libcurl was built shared
  --ca                  CA bundle install path
  --cc                  compiler
  --cflags              preprocessor and compiler flags
  --checkfor [version]  check for (lib)curl of the specified version
  --configure           the arguments given to configure when building curl
  --features            newline separated list of enabled features
  --help                display this help and exit
  --libs                library linking information
  --prefix              curl install prefix
  --protocols           newline separated list of enabled protocols
  --ssl-backends        output the SSL backends libcurl was built to support
  --static-libs         static libcurl library linking information
  --version             output version information
  --vernum              output version as a hexadecimal number
EOF

  exit "$1"
}

if test "$#" -eq 0; then
  usage 1
fi

while test "$#" -gt 0; do
  case "$1" in
  --built-shared)
    echo 'yes'
    ;;

  --ca)
    echo '/data/data/com.termux/files/usr/etc/tls/cert.pem'
    ;;

  --cc)
    echo 'aarch64-linux-android-clang'
    ;;

  --prefix)
    echo "$prefix"
    ;;

  --feature|--features)
    for feature in alt-svc AsynchDNS HSTS HTTP2 HTTP3 HTTPS-proxy IPv6 Largefile libz SSL threadsafe UnixSockets ''; do
      test -n "$feature" && echo "$feature"
    done
    ;;

  --protocols)
    # shellcheck disable=SC2043
    for protocol in DICT FILE FTP FTPS GOPHER GOPHERS HTTP HTTPS IMAP IMAPS IPFS IPNS MQTT MQTTS POP3 POP3S RTSP SCP SFTP SMTP SMTPS TELNET TFTP WS WSS; do
      echo "$protocol"
    done
    ;;

  --version)
    echo 'libcurl 8.21.0'
    exit 0
    ;;

  --checkfor)
    checkfor="$2"
    cmajor=`echo "$checkfor" | cut -d. -f1`
    cminor=`echo "$checkfor" | cut -d. -f2`
    # when extracting the patch part we strip off everything after a
    # dash as that's used for things like version 1.2.3-pre1
    cpatch=`echo "$checkfor" | cut -d. -f3 | cut -d- -f1`

    vmajor=`echo '8.21.0' | cut -d. -f1`
    vminor=`echo '8.21.0' | cut -d. -f2`
    # when extracting the patch part we strip off everything after a
    # dash as that's used for things like version 1.2.3-pre1
    vpatch=`echo '8.21.0' | cut -d. -f3 | cut -d- -f1`

    if test "$vmajor" -gt "$cmajor"; then
      exit 0
    fi
    if test "$vmajor" -eq "$cmajor"; then
      if test "$vminor" -gt "$cminor"; then
        exit 0
      fi
      if test "$vminor" -eq "$cminor"; then
        if test "$cpatch" -le "$vpatch"; then
          exit 0
        fi
      fi
    fi

    echo "requested version $checkfor is newer than existing 8.21.0"
    exit 1
    ;;

  --vernum)
    echo '081500'
    exit 0
    ;;

  --help)
    usage 0
    ;;

  --cflags)
    if test "/data/data/com.termux/files/usr/include" = '/usr/include'; then
      echo ''
    else
      echo " -I/data/data/com.termux/files/usr/include"
    fi
    ;;

  --libs)
    if test "/data/data/com.termux/files/usr/lib" != '/usr/lib' && test "/data/data/com.termux/files/usr/lib" != '/usr/lib64'; then
      curllibdir="-L/data/data/com.termux/files/usr/lib "
    else
      curllibdir=''
    fi
    if test 'yes' = 'no'; then
      echo "${curllibdir}-lcurl -lnghttp3 -lngtcp2_crypto_ossl -lngtcp2 -lnghttp2 -lssh2 -lssh2 -lssl -lcrypto -lssl -lcrypto -lz"
    else
      echo "${curllibdir}-lcurl"
    fi
    ;;

  --ssl-backends)
    echo 'OpenSSL'
    ;;

  --static-libs)
    if test 'yes' != 'no'; then
      echo "/data/data/com.termux/files/usr/lib/libcurl.a -L/data/data/com.termux/files/usr/lib -L/data/data/com.termux/files/usr/lib -L/data/data/com.termux/files/usr/lib -L/data/data/com.termux/files/usr/lib -L/data/data/com.termux/files/usr/lib -L/data/data/com.termux/files/usr/lib -L/data/data/com.termux/files/usr/lib -lnghttp3 -lngtcp2_crypto_ossl -lngtcp2 -lnghttp2 -lssh2 -lssh2 -lssl -lcrypto -lssl -lcrypto -lz"
    else
      echo 'curl was built with static libraries disabled' >&2
      exit 1
    fi
    ;;

  --configure)
    echo " '--disable-dependency-tracking' '--prefix=/data/data/com.termux/files/usr' '--libdir=/data/data/com.termux/files/usr/lib' '--includedir=/data/data/com.termux/files/usr/include' '--sbindir=/data/data/com.termux/files/usr/bin' '--disable-rpath' '--disable-rpath-hack' '--host=aarch64-linux-android' '--enable-ntlm-wb=/data/data/com.termux/files/usr/bin/ntlm_auth' '--with-ca-bundle=/data/data/com.termux/files/usr/etc/tls/cert.pem' '--with-ca-path=/data/data/com.termux/files/usr/etc/tls/certs' '--with-nghttp2' '--with-ngtcp2' '--without-libidn' '--without-libidn2' '--without-librtmp' '--without-brotli' '--without-libpsl' '--with-libssh2' '--with-ssl' '--with-openssl' '--with-nghttp3' '--disable-ares' 'ac_cv_func_getpwuid=yes' '--disable-nls' '--enable-shared' '--enable-static' '--libexecdir=/data/data/com.termux/files/usr/libexec' 'host_alias=aarch64-linux-android' 'CC=aarch64-linux-android-clang' 'CFLAGS= -fstack-protector-strong -Oz' 'LDFLAGS=-L/data/data/com.termux/files/usr/lib -Wl,-rpath=/data/data/com.termux/files/usr/lib -Wl,--enable-new-dtags -Wl,--as-needed -Wl,-z,relro,-z,now -Wl,-z,nodelete' 'CPPFLAGS= -isystem/data/data/com.termux/files/usr/include/c++/v1 -isystem/data/data/com.termux/files/usr/include' 'CPP=aarch64-linux-android-cpp'"
    ;;

  *)
    echo "unknown option: $1"
    usage 1
    ;;
  esac
  shift
done

exit 0

prefix=/data/data/com.termux/files/usr
exec_prefix=${prefix}
libdir=/data/data/com.termux/files/usr/lib
includedir=/data/data/com.termux/files/usr/include
supported_protocols="DICT FILE FTP FTPS GOPHER GOPHERS HTTP HTTPS IMAP IMAPS IPFS IPNS MQTT MQTTS POP3 POP3S RTSP SCP SFTP SMTP SMTPS TELNET TFTP WS WSS"
supported_features="alt-svc AsynchDNS HSTS HTTP2 HTTP3 HTTPS-proxy IPv6 Largefile libz SSL threadsafe UnixSockets"

Name: libcurl
URL: https://curl.se/
Description: Library to transfer files with HTTP, FTP, etc.
Version: 8.21.0
Requires: 
Requires.private: openssl,libssh2,libnghttp2,libngtcp2,libngtcp2_crypto_ossl,libnghttp3
Libs: -L${libdir} -lcurl 
Libs.private: -L/data/data/com.termux/files/usr/lib -L/data/data/com.termux/files/usr/lib -L/data/data/com.termux/files/usr/lib -L/data/data/com.termux/files/usr/lib -L/data/data/com.termux/files/usr/lib -L/data/data/com.termux/files/usr/lib -L/data/data/com.termux/files/usr/lib -lnghttp3 -lngtcp2_crypto_ossl -lngtcp2 -lnghttp2 -lssh2 -lssh2 -lssl -lcrypto -lssl -lcrypto -lz
Cflags: -I${includedir} 
Cflags.private: -DCURL_STATICLIB
